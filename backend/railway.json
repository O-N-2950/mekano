{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "python update_credentials.py && gunicorn wsgi:app --bind 0.0.0.0:$PORT --workers 2",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
